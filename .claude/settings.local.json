{
  "env": {
    "UV_LINK_MODE": "copy"
  },
  "permissions": {
    "allow": [
      "Bash(Get-ChildItem *)",
      "Bash(uv run *)",
      "Bash(echo \"exit $?\")",
      "Bash(cd *)",
      "Bash(UV_LINK_MODE=copy uv run pytest -q)",
      "Bash(UV_LINK_MODE=copy uv run python -m aggregate.extensions.test_suite)"
    ]
  }
}
